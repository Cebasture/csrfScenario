[Unit]
Description=Start Selenium Automation

# Start ONLY after these are fully started
After=network-online.target jsServer.service apache2.service
Requires=jsServer.service apache2.service
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=/bin/sleep 10
ExecStart=/usr/local/bin/automation.sh
KillMode=control-group
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
